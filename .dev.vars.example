# Copy this file to .dev.vars for local Cloudflare Pages development.
# Never commit the real .dev.vars file.

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional production restrictions
PAYROLL_ALLOWED_ORIGIN=http://localhost:8788
PAYROLL_ALLOWED_EMAIL_DOMAIN=
PAYROLL_ALLOWED_ROLES=
